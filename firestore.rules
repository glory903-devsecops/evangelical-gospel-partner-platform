rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 유틸리티 함수: 로그인 여부 확인
    function isSignedIn() {
      return request.auth != null;
    }

    // 유틸리티 함수: 사용자 본인 확인
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // 유틸리티 함수: 관리자 여부 확인
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 유틸리티 함수: 활성 사용자 확인 (블랙리스트 체크)
    function isActive() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isActive == true;
    }

    // 사용자(Users) 컬렉션 규칙
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
    }

    // 공지사항(Notices) 컬렉션 규칙
    match /notices/{noticeId} {
      allow read: if isSignedIn();
      allow create: if isActive() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isAdmin() || (isActive() && resource.data.createdBy == request.auth.uid);
    }

    // 행사(Events) 컬렉션 규칙
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 테넌트(Tenants) 컬렉션 규칙
    match /tenants/{tenantId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      
      // 테넌트별 멤버 서브컬렉션
      match /members/{userId} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || (isSignedIn() && isOwner(userId));
      }
    }

    // 신청(Applications) 컬렉션 규칙
    match /applications/{appId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isActive() && isOwner(request.resource.data.userId);
      allow update: if isActive() && (isOwner(resource.data.userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // 접속 제어(Access Control) 컬렉션 규칙
    match /access_control/{tenantId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 운영자 권한(Operator Roles) 컬렉션 규칙
    match /operator_roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
